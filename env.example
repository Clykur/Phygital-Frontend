# Local dev: prefer `.env.local` at repo root (loaded automatically). Optional fallback: `.env`.
# Production: `.env.production` when NODE_ENV=production.

# Supabase: Dashboard → Project Settings → Database
# Use "URI" under Connection string. Prefer Direct connection (port 5432) for drizzle-kit push
# and for this API. Example:
# postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres
# Or direct:
# postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
#
# Supabase URLs get uselibpqcompat=true automatically in code (pg v8 + drizzle-kit).
# You can still add ?sslmode=require if your dashboard string omits it.
DATABASE_URL=

# If TLS verification fails locally (uncommon), set DATABASE_SSL_INSECURE=1 — do not use in production.
# DATABASE_SSL_INSECURE=1

# DATABASE_POOL_MAX=10
# DATABASE_CONNECTION_TIMEOUT_MS=10000

# API server (@workspace/api-server)
PORT=8787
JWT_SECRET=change-me-at-least-16-chars

# Optional: book cover uploads → Supabase Storage (public bucket).
# Dashboard may label a bucket "Books Images"; the Storage **identifier** is usually lowercase
# (e.g. books-images). Use that exact id for SUPABASE_BOOK_IMAGES_BUCKET.
# Project Settings → API: project URL + service_role key (server only — never ship to the browser).
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_BOOK_IMAGES_BUCKET=books-images
# Optional prefix inside the bucket (no leading slash):
# SUPABASE_BOOK_IMAGES_PREFIX=covers

# Optional seed (see artifacts/api-server/src/seed.ts)
# AUTO_SEED=1
# SEED_ADMIN_EMAIL=admin@example.com
# SEED_ADMIN_PASSWORD=
