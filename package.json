{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "private": true,
  "workspaces": [
    "artifacts/*",
    "lib/*",
    "scripts"
  ],
  "scripts": {
    "typecheck:libs": "tsc --build",
    "build": "pnpm run typecheck && pnpm run build --filter ./artifacts/** --filter ./lib/** --filter ./scripts --if-present",
    "typecheck": "pnpm run typecheck:libs && pnpm run typecheck --filter ./artifacts/** --filter ./lib/** --filter ./scripts --if-present",
  "dev": "pnpm --filter @workspace/phygital-library run dev",
"dev:web": "pnpm --filter @workspace/phygital-library run dev",
"dev:sandbox": "pnpm --filter @workspace/mockup-sandbox run dev",
    "db:generate": "pnpm --filter @workspace/db exec generate",
    "db:migrate": "pnpm --filter @workspace/db exec migrate",
    "db:push": "pnpm --filter @workspace/db exec push"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "kill-port": "^2.0.1",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "@esbuild-kit/esm-loader": "npm:tsx@^4.21.0",
    "esbuild": "0.27.3"
  }
}
