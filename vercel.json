{
  "version": 2,
  "builds": [
    {
      "src": "artifacts/api-server/src/index.ts",
      "use": "@vercel/node"
    },
    {
      "src": "artifacts/phygital-library/package.json",
      "use": "@vercel/static-build",
      "config": { "zeroConfig": true, "outputDirectory": "dist" }
    }
  ],
  "rewrites": [
    { "source": "/", "destination": "/artifacts/api-server/dist/index.mjs" },
    { "source": "/api/(.*)", "destination": "/artifacts/api-server/dist/index.mjs" }
  ]
}