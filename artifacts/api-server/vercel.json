{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/node@3.0.12"
    }
  ],
  "functions": {
    "api.js": {
      "runtime": "nodejs20.x",
      "memory": 1024,
      "maxDuration": 10
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api.js"
    }
  ]
}