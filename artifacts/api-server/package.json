{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_ENV=development npm run build && npx concurrently -k -n build,api \"cross-env NODE_ENV=development node ./build.mjs --watch\" \"cross-env NODE_ENV=development node --enable-source-maps --watch ./dist/index.mjs\"",
    "dev:once": "cross-env NODE_ENV=development npm run build && npm run start",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc -b tsconfig.json"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.104.0",
    "@workspace/api-zod": "*",
    "@workspace/db": "*",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "express": "^5",
    "jose": "^6.0.10",
    "multer": "^2.1.1",
    "pino": "^9",
    "pino-http": "^10",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.3.3",
    "cross-env": "^10.1.0",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0"
  }
}
